branch=$(git symbolic-ref --short -q HEAD)
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  if [ -z "$ALLOW_MAIN_COMMIT" ]; then
    cat >&2 <<EOF
✗ Direct commits to '$branch' are blocked in this repo.

  Create a feature branch first:
    git checkout -b <descriptive-name>

  Rare exception (solo maintainer, trivial fix):
    ALLOW_MAIN_COMMIT=1 git commit ...
EOF
    exit 1
  fi
fi

# Ruff lint + format (mirrors CI: ruff check . && ruff format --check . from backend/)
if [ -d backend ] && command -v uv >/dev/null 2>&1; then
  cd backend
  if ! uv run ruff check . --quiet 2>/dev/null; then
    echo >&2 "✗ ruff check failed. Run: cd backend && uv run ruff check . --fix"
    exit 1
  fi
  if ! uv run ruff format --check . --quiet 2>/dev/null; then
    echo >&2 "✗ ruff format check failed. Run: cd backend && uv run ruff format ."
    exit 1
  fi
  cd ..
fi
